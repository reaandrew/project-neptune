<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=1280, initial-scale=1" />
  <title>$brand_name — Bootstrap</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=$display_font_q:wght@500;700&family=$body_font_q:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bs-primary: $primary;
      --bs-primary-rgb: $primary_rgb;
      --bs-link-color: $primary;
      --bs-link-hover-color: $primary_dim;
    }
    body { font-family: '$body_font', system-ui, sans-serif; color: $text_color; }
    .display-font { font-family: '$display_font', Georgia, serif; }
    .btn-primary {
      --bs-btn-bg: $primary; --bs-btn-border-color: $primary;
      --bs-btn-hover-bg: $primary_dim; --bs-btn-hover-border-color: $primary_dim;
      --bs-btn-active-bg: $primary_dim; --bs-btn-active-border-color: $primary_dim;
      --bs-btn-color: $on_primary; --bs-btn-hover-color: $on_primary; --bs-btn-active-color: $on_primary;
    }
    .btn-outline-primary {
      --bs-btn-color: $primary; --bs-btn-border-color: $primary;
      --bs-btn-hover-color: $on_primary; --bs-btn-hover-bg: $primary; --bs-btn-hover-border-color: $primary;
    }
    .badge.bg-primary { background-color: $primary !important; }
    .nav-link.active { color: $primary !important; }
    .accent-bar { display:inline-block; width:32px; height:2px; background: $primary; vertical-align: middle; margin-right: 10px; }
    .navbar-brand .brand-text { font-family: '$display_font', Georgia, serif; font-weight: 700; letter-spacing: -.01em; }
    .hero { background: linear-gradient(180deg, $primary_pale 0%, #ffffff 100%); }
    .hero-title { font-family: '$display_font', Georgia, serif; font-weight: 700; letter-spacing: -.02em; line-height: 1.05; }
    .hero-title .accent { color: $primary; }
    .feature-card .icon-pill {
      width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center;
      background: $primary_soft; color: $primary; font-size: 22px;
    }
    .stats-card { background: $primary; color: $on_primary; }
    .stats-card h3 { font-family: '$display_font', Georgia, serif; font-weight: 700; font-size: 44px; line-height: 1; }
    .alert-brand { background: $primary_pale; color: $primary_text_on_pale; border-left: 4px solid $primary; }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="#">
        $logo_or_mark
        <span class="brand-text fs-4">$brand_name</span>
      </a>
      <div class="d-none d-lg-flex align-items-center gap-4 ms-4">
        <a class="nav-link active fw-semibold" href="#">Home</a>
        <a class="nav-link fw-semibold text-secondary" href="#">Services</a>
        <a class="nav-link fw-semibold text-secondary" href="#">About</a>
        <a class="nav-link fw-semibold text-secondary" href="#">Contact</a>
      </div>
      <div class="d-flex align-items-center gap-2">
        <button class="btn btn-outline-primary btn-sm fw-semibold">Sign in</button>
        <button class="btn btn-primary btn-sm fw-semibold">Get started</button>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero py-5">
    <div class="container py-4">
      <div class="row align-items-center g-5">
        <div class="col-lg-7">
          <div class="text-uppercase fw-bold text-secondary" style="font-size: 11px; letter-spacing: .18em;">
            <span class="accent-bar"></span>Bootstrap · Brand applied
          </div>
          <h1 class="display-4 hero-title mt-3 mb-3">
            The internet's<br/><span class="accent">most trusted</span> components.
          </h1>
          <p class="lead text-secondary mb-4" style="max-width: 540px;">
            Bootstrap 5 reskinned in your brand colours and typography — the same grid, components, and utilities millions of teams already know.
          </p>
          <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary fw-semibold px-4 py-2">Get started</button>
            <button class="btn btn-outline-primary fw-semibold px-4 py-2">Learn more</button>
            <button class="btn btn-link text-decoration-none fw-semibold">Documentation →</button>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="card shadow border-0 stats-card">
            <div class="card-body p-4">
              <div class="text-uppercase opacity-75 fw-bold" style="font-size: 11px; letter-spacing: .18em;">Stat highlight</div>
              <h3 class="mt-3 mb-2">$brand_initial.0</h3>
              <p class="mb-0 opacity-90">Customer satisfaction rating across the last twelve months — a measurable lift from year one.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature cards -->
  <section class="py-5 bg-white">
    <div class="container">
      <div class="row g-4">
        $feature_cards_bootstrap
      </div>
    </div>
  </section>

  <!-- Alerts + form -->
  <section class="py-5 bg-light border-top">
    <div class="container">
      <div class="row g-4">
        <div class="col-lg-7">
          <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
              <h5 class="display-font fw-bold mb-3">Request a quote</h5>
              <form class="row g-3">
                <div class="col-md-6">
                  <label class="form-label small fw-semibold text-secondary text-uppercase">Name</label>
                  <input type="text" class="form-control" placeholder="Your name" />
                </div>
                <div class="col-md-6">
                  <label class="form-label small fw-semibold text-secondary text-uppercase">Email</label>
                  <input type="email" class="form-control" placeholder="you@example.com" />
                </div>
                <div class="col-12">
                  <label class="form-label small fw-semibold text-secondary text-uppercase">Project notes</label>
                  <textarea class="form-control" rows="2" placeholder="Tell us about it"></textarea>
                </div>
                <div class="col-12 d-flex gap-2 align-items-center">
                  <button type="submit" class="btn btn-primary fw-semibold px-4">Send enquiry</button>
                  <span class="badge bg-primary">Replies &lt; 24h</span>
                  <span class="badge bg-secondary">No-obligation</span>
                </div>
              </form>
            </div>
          </div>
        </div>
        <div class="col-lg-5 d-flex flex-column gap-2">
          <div class="alert alert-success mb-0">
            <strong>Saved.</strong> Your changes have been published.
          </div>
          <div class="alert alert-brand mb-0">
            <strong>Heads up.</strong> Your trial ends in 7 days.
          </div>
          <div class="alert alert-danger mb-0">
            <strong>Something went wrong.</strong> Please try again.
          </div>
          <div class="mt-2 d-flex flex-wrap gap-2">
            <span class="badge bg-primary px-3 py-2">v2.0</span>
            <span class="badge bg-secondary px-3 py-2">Beta</span>
            <span class="badge bg-success px-3 py-2">All systems go</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="py-3 bg-white border-top">
    <div class="container d-flex justify-content-between flex-wrap text-secondary small">
      <span>© $year $brand_name · Bootstrap treatment</span>
      <span>Bootstrap 5 design tokens</span>
    </div>
  </footer>
</body>
</html>
