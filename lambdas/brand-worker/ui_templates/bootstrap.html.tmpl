<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=1280, initial-scale=1" />
  <title>$brand_name — Bootstrap components</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=$display_font_q:wght@500;700&family=$body_font_q:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bs-primary: $primary;
      --bs-primary-rgb: $primary_rgb;
      --bs-link-color: $primary;
      --bs-link-hover-color: $primary_dim;
    }
    body { font-family: '$body_font', system-ui, sans-serif; color: $text_color; padding: 40px; background: #fff; }
    .display-font { font-family: '$display_font', Georgia, serif; }
    .eyebrow { font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: #6c757d; font-weight: 600; }

    /* Buttons */
    .btn-primary {
      --bs-btn-bg: $primary; --bs-btn-border-color: $primary;
      --bs-btn-hover-bg: $primary_dim; --bs-btn-hover-border-color: $primary_dim;
      --bs-btn-active-bg: $primary_dim; --bs-btn-active-border-color: $primary_dim;
      --bs-btn-color: $on_primary; --bs-btn-hover-color: $on_primary; --bs-btn-active-color: $on_primary;
    }
    .btn-outline-primary {
      --bs-btn-color: $primary; --bs-btn-border-color: $primary;
      --bs-btn-hover-color: $on_primary; --bs-btn-hover-bg: $primary; --bs-btn-hover-border-color: $primary;
    }
    .btn-tonal { background: $primary_soft; color: $primary_dim; border-color: transparent; }
    .btn-tonal:hover { background: $primary_pale; color: $primary_dim; }
    .badge.bg-primary { background-color: $primary !important; color: $on_primary; }
    .text-primary { color: $primary !important; }
    .accent-bar { display:inline-block; width:32px; height:2px; background: $primary; vertical-align: middle; margin-right: 10px; }

    /* Form focus */
    .form-control:focus, .form-select:focus { border-color: $primary; box-shadow: 0 0 0 0.2rem rgba($primary_rgb, .22); }
    .form-check-input:checked { background-color: $primary; border-color: $primary; }
    .form-control.is-invalid { border-color: #dc3545; background-image: none; }
    .invalid-feedback { color: #dc3545; }

    /* Alerts */
    .alert-brand { background: $primary_pale; color: $primary_text_on_pale; border-left: 4px solid $primary; }

    .navbar-brand .brand-text { font-family: '$display_font', Georgia, serif; font-weight: 700; letter-spacing: -.01em; }
  </style>
</head>
<body>

  <header class="d-flex align-items-center justify-content-between border-bottom pb-3 mb-4">
    <div class="d-flex align-items-center gap-3">
      $logo_or_mark
      <div>
        <div class="eyebrow">Components</div>
        <div class="display-font fw-bold fs-5">$brand_name — Bootstrap</div>
      </div>
    </div>
    <span class="badge bg-primary text-uppercase px-3 py-2" style="letter-spacing:.14em;">Brand applied</span>
  </header>

  <div class="row g-5">

    <!-- LEFT COLUMN -->
    <div class="col-lg-7">

      <section class="mb-5">
        <div class="eyebrow mb-2"><span class="accent-bar"></span>Buttons</div>
        <div class="d-flex flex-wrap gap-2 mb-2">
          <button class="btn btn-primary fw-semibold">Primary</button>
          <button class="btn btn-tonal fw-semibold">Tonal</button>
          <button class="btn btn-outline-primary fw-semibold">Outline</button>
          <button class="btn btn-link text-primary fw-semibold text-decoration-none">Text</button>
          <button class="btn btn-outline-danger fw-semibold">Destructive</button>
          <button class="btn btn-secondary fw-semibold" disabled>Disabled</button>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <button class="btn btn-primary btn-lg fw-semibold">Large</button>
          <button class="btn btn-primary fw-semibold">Default</button>
          <button class="btn btn-primary btn-sm fw-semibold">Small</button>
          <button class="btn btn-primary rounded-circle" style="width:40px; height:40px; padding:0; font-weight:700;">+</button>
          <button class="btn btn-primary fw-semibold"><i class="bi bi-arrow-right me-1"></i>Continue</button>
        </div>
      </section>

      <section class="mb-5">
        <div class="eyebrow mb-2"><span class="accent-bar"></span>Form controls</div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label small fw-semibold text-uppercase text-secondary">Name</label>
            <input type="text" class="form-control" placeholder="Your name" />
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold text-uppercase text-secondary">Email (focused)</label>
            <input type="email" class="form-control" value="you@example.com" style="border-color: $primary; box-shadow: 0 0 0 0.2rem rgba($primary_rgb, .22);" />
            <div class="form-text">We'll only ever email you about this.</div>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold text-uppercase text-secondary">Project (error)</label>
            <input type="text" class="form-control is-invalid" value="" />
            <div class="invalid-feedback d-block">Required field.</div>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold text-uppercase text-secondary">Plan</label>
            <select class="form-select"><option>Starter</option><option>Pro</option><option>Enterprise</option></select>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-4 mt-3 align-items-center small">
          <div class="form-check m-0">
            <input class="form-check-input" type="checkbox" checked id="cb1">
            <label class="form-check-label" for="cb1">Checkbox · checked</label>
          </div>
          <div class="form-check m-0">
            <input class="form-check-input" type="checkbox" id="cb2">
            <label class="form-check-label" for="cb2">Checkbox · default</label>
          </div>
          <div class="form-check m-0">
            <input class="form-check-input" type="radio" name="rad" id="r1" checked>
            <label class="form-check-label" for="r1">Radio · selected</label>
          </div>
          <div class="form-check form-switch m-0">
            <input class="form-check-input" type="checkbox" checked id="sw1">
            <label class="form-check-label" for="sw1">Toggle · on</label>
          </div>
        </div>
      </section>

      <section class="mb-5">
        <div class="eyebrow mb-2"><span class="accent-bar"></span>Cards</div>
        <div class="row g-2">
          <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
              <div class="card-body p-3">
                <div class="eyebrow">Basic</div>
                <h6 class="display-font fw-bold mt-1 mb-1">Card title</h6>
                <p class="small text-secondary mb-0">Short supporting line.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
              <div class="card-img-top display-font fw-bold d-flex align-items-center justify-content-center" style="height:80px; background: linear-gradient(135deg, $primary, $primary_dim); color: $on_primary; font-size:30px;">$brand_initial</div>
              <div class="card-body p-3">
                <div class="eyebrow">Media card</div>
                <h6 class="display-font fw-bold mt-1 mb-1">Featured</h6>
                <p class="small text-secondary mb-0">Hero panel above.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
              <div class="card-body p-3 d-flex flex-column">
                <div class="eyebrow">Action card</div>
                <h6 class="display-font fw-bold mt-1 mb-1">With CTA</h6>
                <p class="small text-secondary flex-grow-1 mb-2">CTA in the footer.</p>
                <button class="btn btn-primary btn-sm fw-semibold align-self-start">Open</button>
              </div>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-lg-5">

      <section class="mb-5">
        <div class="eyebrow mb-2"><span class="accent-bar"></span>Badges &amp; pills</div>
        <div class="d-flex flex-wrap gap-2">
          <span class="badge bg-primary fw-semibold px-3 py-2">Solid</span>
          <span class="badge fw-semibold px-3 py-2" style="background: $primary_soft; color: $primary_dim;">Tonal</span>
          <span class="badge fw-semibold px-3 py-2" style="background: transparent; color: $primary; border: 1px solid $primary;">Outline</span>
          <span class="badge bg-secondary fw-semibold px-3 py-2">Neutral</span>
          <span class="badge bg-success fw-semibold px-3 py-2">Success</span>
          <span class="badge bg-warning text-dark fw-semibold px-3 py-2">Warning</span>
          <span class="badge bg-danger fw-semibold px-3 py-2">Error</span>
          <span class="badge bg-primary fw-semibold px-3 py-2"><span class="d-inline-block rounded-circle me-1" style="width:6px; height:6px; background:white;"></span>Live</span>
        </div>
      </section>

      <section class="mb-5">
        <div class="eyebrow mb-2"><span class="accent-bar"></span>Alerts</div>
        <div class="d-flex flex-column gap-2">
          <div class="alert alert-success mb-0 py-2 px-3">
            <strong class="d-block">Saved successfully</strong>
            <small>Your changes have been published.</small>
          </div>
          <div class="alert alert-brand mb-0 py-2 px-3">
            <strong class="d-block">Heads up</strong>
            <small>Your trial ends in 7 days.</small>
          </div>
          <div class="alert alert-warning mb-0 py-2 px-3">
            <strong class="d-block">Action required</strong>
            <small>Verify your email to continue.</small>
          </div>
          <div class="alert alert-danger mb-0 py-2 px-3">
            <strong class="d-block">Something went wrong</strong>
            <small>Please try again in a moment.</small>
          </div>
        </div>
      </section>

      <section class="mb-5">
        <div class="eyebrow mb-2"><span class="accent-bar"></span>Avatars &amp; progress</div>
        <div class="d-flex align-items-center gap-2 mb-3">
          <div class="rounded-circle d-grid align-items-center justify-content-center fw-bold" style="width:40px; height:40px; background: $primary; color: $on_primary;">${brand_initial}A</div>
          <div class="rounded-circle d-grid align-items-center justify-content-center fw-bold" style="width:40px; height:40px; background: $primary_soft; color: $primary_dim;">JD</div>
          <div class="rounded-circle d-grid align-items-center justify-content-center fw-bold bg-secondary text-white" style="width:40px; height:40px;">SK</div>
          <div class="d-flex" style="margin-left: 8px;">
            <div class="rounded-circle d-grid align-items-center justify-content-center fw-bold border border-2 border-white" style="width:34px; height:34px; background: $primary; color: $on_primary;">A</div>
            <div class="rounded-circle d-grid align-items-center justify-content-center fw-bold border border-2 border-white ms-n2" style="width:34px; height:34px; background: $primary_soft; color: $primary_dim; margin-left:-8px;">B</div>
            <div class="rounded-circle d-grid align-items-center justify-content-center fw-bold border border-2 border-white bg-secondary text-white" style="width:34px; height:34px; margin-left:-8px;">+4</div>
          </div>
        </div>
        <div class="d-flex justify-content-between small text-secondary fw-semibold"><span>Progress</span><span>72%</span></div>
        <div class="progress mt-1" style="height:8px;">
          <div class="progress-bar" role="progressbar" style="width: 72%; background-color: $primary;" aria-valuenow="72" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
      </section>

    </div>
  </div>
</body>
</html>
